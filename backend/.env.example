# Variables de entorno — Chocolates Helena Backend
# ⚠️ NUNCA subas este archivo a GitHub (ya está en .gitignore)

# Puerto del servidor
PORT=3000

# Email (Gmail) — Para envío de correos con Nodemailer
# Usa una "Contraseña de Aplicación" de Gmail:
# Google Account → Seguridad → Verificación en 2 pasos → Contraseñas de aplicación
EMAIL_USER=tu-correo@gmail.com
EMAIL_PASS=xxxx-xxxx-xxxx-xxxx

# Gemini AI (opcional en backend, ya lo usa el frontend)
GEMINI_API_KEY=tu_clave_gemini_aqui

# URL del frontend (para CORS en producción)
FRONTEND_URL=https://tu-sitio.netlify.app
